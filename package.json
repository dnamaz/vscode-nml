{
  "name": "nml-language",
  "displayName": "NML Language Support",
  "description": "Language support for NML (Neural Machine Language) — syntax highlighting, diagnostics, completions, hover, and more.",
  "version": "0.1.0",
  "publisher": "nml",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dnamaz/nml"
  },
  "icon": "nml-icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:nml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nml",
        "aliases": ["NML", "Neural Machine Language"],
        "extensions": [".nml"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "nml-data",
        "aliases": ["NML Data"],
        "extensions": [".nml.data"]
      }
    ],
    "grammars": [
      {
        "language": "nml",
        "scopeName": "source.nml",
        "path": "./syntaxes/nml.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "NML",
      "properties": {
        "nml.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to the Python interpreter used to run the NML language server."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "typescript": "^5.3.0"
  }
}
